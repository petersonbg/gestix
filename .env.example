DEBUG=False
SECRET_KEY=alterar-esta-chave
# O hostname real e HOSTNAME.local sao adicionados automaticamente.
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# A rede local usa HTTP. Ative somente depois de configurar HTTPS corretamente.
USE_HTTPS=False
# Mantenha True somente em rede local. Em producao, sirva /media pelo proxy reverso.
SERVE_MEDIA_FILES=True
# O launcher define automaticamente http://HOSTNAME:PORTA.

DB_NAME=gestix
DB_USER=gestix
DB_PASSWORD=troque-esta-senha
DB_HOST=localhost
DB_PORT=5432

RUNNING_IN_DOCKER=True
BACKUP_ROOT=/app/backups
BACKUP_MAX_UPLOAD_SIZE=524288000
WEB_PORT=8000
